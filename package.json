{
  "name": "omp-langfuse",
  "version": "0.1.0",
  "description": "Langfuse observability extension for OMP (oh-my-pi). One trace per agent run with self-computed cost.",
  "type": "module",
  "main": "dist/index.js",
  "omp": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "build": "esbuild index.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/index.js --log-level=warning",
    "probe": "echo 'Build then run:  npm run build && omp -e ./dist/index.js -p \"say hi\"'"
  },
  "keywords": [
    "omp-package",
    "langfuse",
    "observability",
    "tracing",
    "monitoring",
    "oh-my-pi",
    "omp",
    "extension"
  ],
  "dependencies": {
    "@langfuse/client": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "2.8.0",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/sdk-trace-base": "2.8.0"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": ">=16.0.0"
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "16.3.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
